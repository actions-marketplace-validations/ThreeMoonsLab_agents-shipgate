{
  "$defs": {
    "Finding": {
      "additionalProperties": true,
      "properties": {
        "agent_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Id"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "check_id": {
          "title": "Check Id",
          "type": "string"
        },
        "confidence": {
          "default": "medium",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "evidence": {
          "additionalProperties": true,
          "title": "Evidence",
          "type": "object"
        },
        "fingerprint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fingerprint"
        },
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "recommendation": {
          "title": "Recommendation",
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        },
        "source": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "suppressed": {
          "default": false,
          "title": "Suppressed",
          "type": "boolean"
        },
        "suppression_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suppression Reason"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "tool_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Id"
        },
        "tool_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Name"
        }
      },
      "required": [
        "check_id",
        "title",
        "severity",
        "category",
        "recommendation"
      ],
      "title": "Finding",
      "type": "object"
    },
    "ReportSummary": {
      "properties": {
        "critical_count": {
          "default": 0,
          "title": "Critical Count",
          "type": "integer"
        },
        "evidence_coverage": {
          "default": "static",
          "title": "Evidence Coverage",
          "type": "string"
        },
        "high_count": {
          "default": 0,
          "title": "High Count",
          "type": "integer"
        },
        "human_review_recommended": {
          "default": false,
          "title": "Human Review Recommended",
          "type": "boolean"
        },
        "info_count": {
          "default": 0,
          "title": "Info Count",
          "type": "integer"
        },
        "low_count": {
          "default": 0,
          "title": "Low Count",
          "type": "integer"
        },
        "medium_count": {
          "default": 0,
          "title": "Medium Count",
          "type": "integer"
        },
        "status": {
          "title": "Status",
          "type": "string"
        },
        "suppressed_count": {
          "default": 0,
          "title": "Suppressed Count",
          "type": "integer"
        }
      },
      "required": [
        "status"
      ],
      "title": "ReportSummary",
      "type": "object"
    },
    "SourceReference": {
      "additionalProperties": true,
      "properties": {
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location"
        },
        "ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ref"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "SourceReference",
      "type": "object"
    },
    "ToolSurfaceSummary": {
      "properties": {
        "high_risk_tools": {
          "title": "High Risk Tools",
          "type": "integer"
        },
        "missing_descriptions": {
          "default": 0,
          "title": "Missing Descriptions",
          "type": "integer"
        },
        "sources": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Sources",
          "type": "object"
        },
        "total_tools": {
          "title": "Total Tools",
          "type": "integer"
        },
        "wildcard_tools": {
          "default": 0,
          "title": "Wildcard Tools",
          "type": "integer"
        }
      },
      "required": [
        "total_tools",
        "high_risk_tools"
      ],
      "title": "ToolSurfaceSummary",
      "type": "object"
    }
  },
  "$id": "https://github.com/ThreeMoonsLab/agents-shipgate/schemas/report-schema.v0.1.json",
  "additionalProperties": true,
  "properties": {
    "agent": {
      "additionalProperties": true,
      "title": "Agent",
      "type": "object"
    },
    "api_surface": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "model_config_present": {
              "type": "boolean"
            },
            "policy_rule_count": {
              "minimum": 0,
              "type": "integer"
            },
            "prompt_file_count": {
              "minimum": 0,
              "type": "integer"
            },
            "response_format_count": {
              "minimum": 0,
              "type": "integer"
            },
            "test_case_count": {
              "minimum": 0,
              "type": "integer"
            },
            "tool_file_count": {
              "minimum": 0,
              "type": "integer"
            },
            "trace_sample_count": {
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "prompt_file_count",
            "tool_file_count",
            "response_format_count",
            "model_config_present",
            "test_case_count",
            "trace_sample_count",
            "policy_rule_count"
          ],
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Api Surface"
    },
    "environment": {
      "additionalProperties": true,
      "title": "Environment",
      "type": "object"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "generated_reports": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Generated Reports",
      "type": "object"
    },
    "project": {
      "additionalProperties": true,
      "title": "Project",
      "type": "object"
    },
    "recommended_actions": {
      "items": {
        "type": "string"
      },
      "title": "Recommended Actions",
      "type": "array"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1",
      "title": "Schema Version",
      "type": "string"
    },
    "source_warnings": {
      "items": {
        "type": "string"
      },
      "title": "Source Warnings",
      "type": "array"
    },
    "summary": {
      "$ref": "#/$defs/ReportSummary"
    },
    "tool_inventory": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "auth_scopes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "confidence": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "owner": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "risk_tag_confidence": {
            "additionalProperties": {
              "enum": [
                "low",
                "medium",
                "high"
              ],
              "type": "string"
            },
            "type": "object"
          },
          "risk_tags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "source_ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "source_type": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "source_type",
          "risk_tags",
          "confidence"
        ],
        "type": "object"
      },
      "title": "Tool Inventory",
      "type": "array"
    },
    "tool_surface": {
      "$ref": "#/$defs/ToolSurfaceSummary"
    }
  },
  "required": [
    "run_id",
    "project",
    "agent",
    "environment",
    "summary",
    "tool_surface"
  ],
  "title": "Agents Shipgate Readiness Report v0.1",
  "type": "object",
  "x-compatibility": {
    "check_ids": "Built-in check IDs are stable public identifiers.",
    "schema_version": "0.1",
    "stability": "Keys are intended to be stable within the 0.1 report line; additive fields may be introduced."
  }
}
